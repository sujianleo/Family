# TypeScript + Next.js + Supabase
NEXT_PUBLIC_SUPABASE_URL=
# Optional public HTTPS endpoint. On LAN the browser automatically uses the
# current NAS hostname/IP with NEXT_PUBLIC_SUPABASE_LAN_PORT instead.
NEXT_PUBLIC_SUPABASE_PUBLIC_URL=
NEXT_PUBLIC_SUPABASE_LAN_PORT=8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_FAMILY_ID=
NEXT_PUBLIC_SUPABASE_MEMBER_ID=
NEXT_PUBLIC_SUPABASE_CORE_SPACE_ID=

# Server-only Supabase writes. Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_INTERNAL_URL=
SUPABASE_DEFAULT_FAMILY_ID=
SUPABASE_DEFAULT_MEMBER_ID=
SUPABASE_DEFAULT_CORE_SPACE_ID=
SUPABASE_VOICE_BUCKET=voice-notes

# Production API protection. Keep server-only values out of the browser.
NEXT_PUBLIC_FAMILY_APP_AUTH_REQUIRED=true
NEXT_PUBLIC_FAMILY_APP_AUTH_PROVIDER=supabase
# Optional build-time LAN address shown in first-run setup. Users can edit it in the browser.
FAMILY_APP_LAN_ADDRESS=
FAMILY_APP_AUTH_REQUIRED=true
FAMILY_APP_CONFIRMATION_SECRET=replace-with-a-long-random-server-secret

# Voice transcription backend.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Offline fallback. Install requirements-speech.txt into .venv.
LOCAL_TRANSCRIBE_MODEL=Systran/faster-whisper-small
LOCAL_TRANSCRIBE_DEVICE=cpu
LOCAL_TRANSCRIBE_COMPUTE_TYPE=int8
LOCAL_TRANSCRIBE_ALLOW_DOWNLOAD=0

# DeepSeek OpenAI-compatible models.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Legacy fallback for fast route/chat if DEEPSEEK_MODEL_FAST is unset.
DEEPSEEK_MODEL=
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_DEEP=deepseek-v4-pro

# Cross-platform PWA notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
NOTIFICATION_DISPATCH_KEY=replace-with-a-long-random-dispatch-key
