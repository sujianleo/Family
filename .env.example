# Family stores its database inside the persistent /app/data volume.
FAMILY_APP_BACKEND=sqlite
NEXT_PUBLIC_FAMILY_APP_BACKEND=sqlite
FAMILY_APP_SQLITE_PATH=/app/data/family.sqlite

# Local account protection.
NEXT_PUBLIC_FAMILY_APP_AUTH_REQUIRED=true
NEXT_PUBLIC_FAMILY_APP_AUTH_PROVIDER=local
FAMILY_APP_LAN_ADDRESS=
FAMILY_APP_AUTH_REQUIRED=true
# The Docker image creates and persists local security keys automatically.

# Voice transcription backend.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Offline fallback. Install requirements-speech.txt into .venv.
LOCAL_TRANSCRIBE_MODEL=Systran/faster-whisper-small
LOCAL_TRANSCRIBE_DEVICE=cpu
LOCAL_TRANSCRIBE_COMPUTE_TYPE=int8
LOCAL_TRANSCRIBE_ALLOW_DOWNLOAD=0

# DeepSeek OpenAI-compatible models.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Legacy fallback for fast route/chat if DEEPSEEK_MODEL_FAST is unset.
DEEPSEEK_MODEL=
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_DEEP=deepseek-v4-pro

# Cross-platform PWA notifications.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
