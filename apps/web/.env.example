NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_FAMILY_ID=
NEXT_PUBLIC_SUPABASE_MEMBER_ID=
NEXT_PUBLIC_SUPABASE_CORE_SPACE_ID=

SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DEFAULT_FAMILY_ID=
SUPABASE_DEFAULT_MEMBER_ID=
SUPABASE_DEFAULT_CORE_SPACE_ID=
SUPABASE_VOICE_BUCKET=voice-notes

# Production API protection. The browser flag enables the Magic Link entry UI;
# the server flag verifies each bearer session against family_members.user_id.
NEXT_PUBLIC_FAMILY_APP_AUTH_REQUIRED=true
# Optional build-time LAN address shown in first-run setup. Users can edit it in the browser.
NEXT_PUBLIC_FAMILY_APP_LAN_ADDRESS=
FAMILY_APP_AUTH_REQUIRED=true
FAMILY_APP_CONFIRMATION_SECRET=replace-with-a-long-random-server-secret
FAMILY_APP_ALLOW_FILE_FALLBACK=false
# Only for a public demo whose synthetic members are assigned by the gateway.
FAMILY_APP_ALLOW_UNBOUND_INVITE_ACTORS=false
# Synthetic task/group/resource records are opt-in. Never enable them for a real family deployment.
FAMILY_APP_DEMO_DATA=false
INVITE_CODE_SECRET=replace-with-a-different-long-random-server-secret
NEXT_PUBLIC_WECHAT_AUTH_PROVIDER=
GUEST_CHAT_SESSION_SECRET=replace-with-a-long-random-server-secret
GUEST_CHAT_CODE_SECRET=replace-with-another-long-random-server-secret

OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Offline fallback. Install project/requirements-speech.txt into project/.venv.
LOCAL_TRANSCRIBE_MODEL=Systran/faster-whisper-small
LOCAL_TRANSCRIBE_DEVICE=cpu
LOCAL_TRANSCRIBE_COMPUTE_TYPE=int8
LOCAL_TRANSCRIBE_ALLOW_DOWNLOAD=0

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=
DEEPSEEK_MODEL_FAST=deepseek-v4-flash
DEEPSEEK_MODEL_DEEP=deepseek-v4-pro

# PWA Web Push. Private values are also configured as Supabase Edge Function secrets.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
NOTIFICATION_DISPATCH_KEY=replace-with-a-long-random-dispatch-key
